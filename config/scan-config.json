{
  "default_scan_mode": "full",
  "nuclei_severity": "critical,high,medium,low,info",
  "nuclei_tags": "wordpress,wp-plugin,wp-theme,cve,xss,sqli,lfi,rfi,ssrf,exposure,misconfig",
  "nuclei_tags_wordpress": "wordpress,wp-plugin,wp-theme,cve,xss,sqli,lfi,ssrf,exposure,misconfig",
  "nuclei_tags_joomla": "joomla,cve,exposure,misconfig,default-login",
  "nuclei_tags_drupal": "drupal,cve,exposure,misconfig,default-login",
  "nuclei_tags_api": "api,graphql,cve,exposure,misconfig,default-login",
  "nuclei_tags_broad": "cve,rce,lfi,sqli,xss,ssrf,exposure,misconfig,default-login,redirect,takeover,credentials",
  "nuclei_rate_limit": 25,
  "wpscan_enumerate": "vp,vt,u",
  "wpscan_max_threads": 1,
  "zap_scan_policy": "Default Policy",
  "zap_ajax_spider": false,
  "sqlmap_level": 2,
  "sqlmap_risk": 2,
  "nikto_tuning": "1234567890abc",
  "nikto_pause_seconds": 1,
  "sslyze_scan_commands": "certificate_info,ssl_2_0_cipher_suites,ssl_3_0_cipher_suites,tls_1_0_cipher_suites,tls_1_1_cipher_suites,tls_1_2_cipher_suites,tls_1_3_cipher_suites,heartbleed",
  "whatweb_aggression": 2,
  "whatweb_max_threads": 8,
  "httpx_probes": "status-code,title,tech-detect,content-length,web-server",
  "httpx_rate_limit": 25,
  "content_wordlist": "",
  "output_formats": ["html", "markdown", "json"],
  "parallel_scans": true,
  "max_parallel_tools": 3,
  "max_parallel_heavy_tools": 2,
  "timeout_per_tool_seconds": 600
}
